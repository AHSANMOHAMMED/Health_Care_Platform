# ===============================================
# MEDICONNECT LANKA - ENVIRONMENT CONFIGURATION
# ===============================================

# PostGreSQL Configuration
DB_USER=root
DB_PASSWORD=rootpassword

# RabbitMQ Configuration
RMQ_USER=root
RMQ_PASSWORD=rootpassword

# JWT Security
# Ensure this secret is at least 256-bit (Base64 encoded string recommended)
JWT_SECRET=mediconnect_super_secret_jwt_key_that_must_be_long_enough
JWT_EXPIRATION=86400000

# Google Gemini 2.0 Flash AI API Key for Symptom Checker
GEMINI_API_KEY=insert_your_google_ai_studio_key_here

# Frontend Configuration
VITE_API_GATEWAY_URL=http://localhost:8080/api
