# JWT (HMAC key must be >= 256 bits for HS256; use a long random string in real deployments)
JWT_SECRET=dev-change-me-use-at-least-32-bytes-secret-key!!

# Agora (https://console.agora.io) — RTC token generation
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# PayHere (https://support.payhere.lk) — sandbox credentials
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true

# Twilio (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_FROM_EMAIL=

# OpenAI (optional symptom checker)
OPENAI_API_KEY=

# Defaults for local Docker Compose (usually no need to change)
EUREKA_URL=http://discovery-service:8761/eureka
SPRING_PROFILES_ACTIVE=docker
